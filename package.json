{
  "name": "spotplanner",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync && npm run paraglide || echo ''",
    "check": "npm run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest",
    "test": "npm run paraglide && vitest --run"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "leaflet-rotate": "^0.2.8",
    "qrcode-generator": "^1.5.2"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.20.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.66.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^22.20.0",
    "@types/qrcode-generator": "^0.0.16",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
